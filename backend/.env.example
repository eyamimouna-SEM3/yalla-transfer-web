# Exemple de variables d'environnement pour le backend
# Ne jamais mettre de secrets réels dans le dépôt.

DATABASE_URL="postgresql://user:password@host:5432/yalla_transfer?schema=public"
JWT_SECRET="change_this_secret"
PORT=3000
CORS_ORIGIN="*"

# Google OAuth (optionnel)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# SMTP (optionnel)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@example.com"
SMTP_PASS="your_email_app_password"
SMTP_FROM="Yalla Transfer <your_email@example.com>"
