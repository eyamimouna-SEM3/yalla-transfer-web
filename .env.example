# =======================================================================
# Yalla Transfer Web Frontend — Template d'environnement
# Copie ce fichier en .env.local pour le dev.
# Sur Vercel : configurer les vars dans Project Settings → Environment Variables.
# =======================================================================

# ── URL du backend
#
# En LOCAL avec Vite proxy (mkcert HTTPS) :
#   VITE_API_URL=/api
# Le proxy Vite redirige automatiquement vers http://localhost:3000.
#
# En PRODUCTION sur Vercel :
#   VITE_API_URL=https://yalla-transfer-backend.onrender.com/api
# (ou ton URL Render réelle)
VITE_API_URL=/api
